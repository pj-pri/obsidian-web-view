# Absolute path to your Obsidian vault directory (required for live vault mode)
OBSIDIAN_VAULT_DIR=/path/to/your/vault

# Port the server listens on (default: 5173)
PORT=5173

# Optional Basic Auth for browser/API access.
# Authentication is enabled only when BOTH BASIC_AUTH_USER and BASIC_AUTH_PASSWORD are set.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
# Name shown in the browser's Basic Auth login prompt.
BASIC_AUTH_REALM=Obsidian Web Vault

# Optional per-IP request rate limiting.
# Example: 300 requests per 60 seconds.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300

# Optional per-IP authentication failure limiting.
# Example: allow up to 10 failed Basic Auth attempts per 10 minutes.
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX_FAILURES=10

# Enable default security headers and Content Security Policy.
# Set to "false" only if you need to relax headers for custom deployments.
SECURITY_HEADERS_ENABLED=true

# Obsidian Local REST API plugin (optional)
OBSIDIAN_API_URL=http://127.0.0.1:27123
OBSIDIAN_API_KEY=your-api-key-here
